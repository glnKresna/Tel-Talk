rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users: hanya boleh akses dokumen miliknya sendiri.
    match /users/{userId} {
      allow read: if isOwner(userId);

      // Batasi field yang boleh diubah: nama (display name), bio, photoURL.
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['nama', 'bio', 'photoURL'])
        && request.resource.data.userID == resource.data.userID;

      allow create: if isOwner(userId);
      allow delete: if false;
    }

    // Rooms/messages: masih permissive untuk fitur chat saat ini (sesuaikan nanti).
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /messages/{messageId} {
        allow read: if isSignedIn();

        // Create: user hanya boleh membuat pesan atas nama dirinya sendiri.
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid;

        // Update:
        // - Owner boleh edit isi pesan miliknya sendiri
        // - Siapapun boleh toggle pin (hanya field isPinned)
        allow update: if isSignedIn()
          && (
            // Owner editing own message
            (resource.data.senderId == request.auth.uid
              && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isiPesan', 'editedAt']))
            // Anyone pin/unpin
            || request.resource.data.diff(resource.data).changedKeys().hasOnly(['isPinned'])
          );

        // Delete: hanya owner pesan yang boleh hapus.
        allow delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
